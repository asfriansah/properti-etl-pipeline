# ==========================================
# 🐍 Python Environment & Cache
# ==========================================
# Ignore virtual environment folder (very heavy when uploaded)
etl_venv/
venv/
env/
ENV/

# Ignoring Python cache folder
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.ipynb_checkpoints/

# ==========================================
# 🧠 Machine Learning Artifacts & Models
# ==========================================
# Ignoring serialized model files (.pkl or .joblib)
# Because these files can be regenerated by running train_model.py
*.pkl
*.joblib
*.h5
*.onnx

# ==========================================
# 📊 Data & Local Databases
# ==========================================
# Ignoring raw data files of large size
*.csv
*.xlsx
*.xls
*.json
data/

# Ignoring local database files
*.sql
*.sqlite
*.db

# ==========================================
# 🔑 Security & Credentials
# ==========================================
# Ignoring file that contains database passwords or API Keys
.env
secret.json
credentials.py

# ==========================================
# 💻 OS & IDE Specific Files
# ==========================================
# Ignoring IDE/editor specific files
.vscode/
.idea/
.DS_Store
Thumbs.db